                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"plan_id\": {{plan_id}},\n  \"payment_method_id\": \"pm_card_visa\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/subscriptions/subscribe",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "subscriptions",
                                "subscribe"
                            ]
                        }
                    },
                    "response": []
